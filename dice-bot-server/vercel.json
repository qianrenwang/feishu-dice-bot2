{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "FEISHU_APP_ID": "cli_aa881a6b85395bd7",
    "FEISHU_APP_SECRET": "@feishu-app-secret"
  }
}